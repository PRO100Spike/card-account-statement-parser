# -----------------------------------------------------------------------------
# Общие правила для Python (взяты из шаблона GitHub)
# -----------------------------------------------------------------------------

# Файлы байт-кода / оптимизированные / DLL-файлы
__pycache__/
*.py[cod]
*$py.class

# Распределение / упаковка
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Логи установщика
pip-log.txt
pip-delete-this-directory.txt

# Виртуальные окружения
# Если вы используете venv/virtualenv, эти папки содержат все установленные пакеты.
# Их НИКОГДА не следует коммитить.
venv/
env/
.venv/
.env

# Локальные/конфигурационные файлы
*.sqlite
*.db
.env
.flaskenv

# IPython/Jupyter Notebook (если используются)
.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Правила для Alembic (миграции БД)
# -----------------------------------------------------------------------------

# Файлы, которые обычно генерирует Alembic, но не нужно коммитить:
# Если ваш env.py или alembic.ini создают какие-либо файлы логов, добавьте их.

# Если вы используете SQLite и храните базу данных в корне проекта
# (часто используется для тестовых или локальных БД):
# Внимание: замените 'your_app.db' на фактическое имя вашего локального файла БД.
# my_database.db
# *.sqlite
# Если вы используете Alembic для работы с БД, убедитесь, что
# папка миграций (обычно 'alembic/versions') КОММИТИТСЯ,
# но не коммитьте скомпилированные Python-файлы внутри нее.
alembic/**/__pycache__/

# -----------------------------------------------------------------------------
# Правила для Pandas / Анализа данных
# -----------------------------------------------------------------------------

# Файлы данных, которые генерируются или являются слишком большими
# (не коммитьте сырые данные, которые можно скачать или сгенерировать)
*.csv
*.xlsx
*.parquet
*.feather
*.pkl
*.pickle
*.json
*.h5
*.hd5

# Если вы сохраняете большие модели машинного обучения
# *.joblib
# *.onnx

# -----------------------------------------------------------------------------
# Правила для IDE / Редакторов (если используются)
# -----------------------------------------------------------------------------

# VS Code
.vscode/

# PyCharm/IntelliJ
.idea/